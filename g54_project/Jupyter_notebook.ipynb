    "import pandas as pd\n",
    "import sqlite3\n",
    "\n",
    "df = pd.read_csv(\"G54_data (1).csv\")\n",
    "\n",
    "conn = sqlite3.connect(\"Bases_dados.db\")\n",
    "\n",
    "df.to_sql(\"Researcher\", conn, if_exists = \"replace\", index = False)\n",
    "\n",
    "conn.close()\n",
    "print(\"Sucesso! Agora podes abrir o ficheiro .db no DB Browser.\")\n"
   ]
